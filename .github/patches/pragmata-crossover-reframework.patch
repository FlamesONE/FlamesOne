From 1cc0fb79148feb1b3e930ed8e2f5330bf91de23a Mon Sep 17 00:00:00 2001
From: FlamesONE <xenozf@gmail.com>
Date: Mon, 27 Apr 2026 12:16:55 +0500
Subject: [PATCH 1/3] Patch PRAGMATA CrossOver ultrawide startup

---
 src/Main.cpp        |  2 +-
 src/Mods.cpp        | 28 ++++++++++++++---------
 src/REFramework.cpp | 54 +++++++++++++++++++++++++++++++++++++--------
 3 files changed, 64 insertions(+), 20 deletions(-)

diff --git a/src/Main.cpp b/src/Main.cpp
index 2d4c8d1..b39a950 100644
--- a/src/Main.cpp
+++ b/src/Main.cpp
@@ -108,7 +108,7 @@ void startup_thread(HMODULE reframework_module) {
                 }
                 utility::unlink(*our_dll);
             }
-        } else if (gi.is_dd2() || gi.tdb_ver() >= 74) {
+        } else if (!gi.is_pragmata() && (gi.is_dd2() || gi.tdb_ver() >= 74)) {
             if (!g_success_made_ldr_notification) {
                 utility::spoof_module_paths_in_exe_dir();
             }
diff --git a/src/Mods.cpp b/src/Mods.cpp
index e8509d4..1a6bbe8 100644
--- a/src/Mods.cpp
+++ b/src/Mods.cpp
@@ -24,31 +24,38 @@
 #include "Mods.hpp"
 
 Mods::Mods() {
+    const auto& gi = sdk::GameIdentity::get();
+    const bool minimal_pragmata_crossover = gi.is_pragmata();
+
     m_mods.emplace_back(BackBufferRenderer::get());
     m_mods.emplace_back(REFrameworkConfig::get());
 
     // IntegrityCheckBypass: only for games with anti-tamper (REENGINE_AT)
-    if (sdk::GameIdentity::get().is_reengine_at()) {
+    if (gi.is_reengine_at()) {
         m_mods.emplace_back(IntegrityCheckBypass::get_shared_instance());
     }
 
 #ifndef BAREBONES
     m_mods.emplace_back(MethodDatabase::get());
     m_mods.emplace_back(Hooks::get());
-    m_mods.emplace_back(LooseFileLoader::get());
 
-    if (sdk::GameIdentity::get().tdb_ver() >= 81) {
-        m_mods.emplace_back(FaultyFileDetector::get());
+    if (!minimal_pragmata_crossover) {
+        m_mods.emplace_back(LooseFileLoader::get());
+
+        if (gi.tdb_ver() >= 81) {
+            m_mods.emplace_back(FaultyFileDetector::get());
+        }
     }
 
-    m_mods.emplace_back(VR::get());
+    if (!minimal_pragmata_crossover) {
+        m_mods.emplace_back(VR::get());
+    }
 
-    if (sdk::GameIdentity::get().is_re8() || sdk::GameIdentity::get().is_re7()) {
+    if (!minimal_pragmata_crossover && (gi.is_re8() || gi.is_re7())) {
         m_mods.emplace_back(RE8VR::get());
     }
 
     {
-        const auto& gi = sdk::GameIdentity::get();
         if (!gi.is_re8() && (gi.is_re2() || gi.is_re3())) {
             m_mods.emplace_back(FirstPerson::get());
         }
@@ -59,15 +66,16 @@ Mods::Mods() {
     m_mods.emplace_back(Graphics::get());
 
     {
-        const auto& gi = sdk::GameIdentity::get();
         if (gi.is_re2() || gi.is_re3() || gi.is_re8()) {
             m_mods.emplace_back(std::make_unique<ManualFlashlight>());
         }
     }
 
-    m_mods.emplace_back(std::make_unique<FreeCam>());
+    if (!minimal_pragmata_crossover) {
+        m_mods.emplace_back(std::make_unique<FreeCam>());
+    }
 
-    if (sdk::GameIdentity::get().tdb_ver() > 49) {
+    if (!minimal_pragmata_crossover && gi.tdb_ver() > 49) {
         m_mods.emplace_back(std::make_unique<SceneMods>());
     }
 
diff --git a/src/REFramework.cpp b/src/REFramework.cpp
index 6712820..4e4597a 100644
--- a/src/REFramework.cpp
+++ b/src/REFramework.cpp
@@ -206,6 +206,38 @@ using LdrRegisterDllNotification_t = NTSTATUS (*) (
 std::optional<std::filesystem::path> g_current_game_path{};
 bool g_success_made_ldr_notification{false};
 
+static bool should_use_module_storage_workaround(const sdk::GameIdentity& gi) {
+    if (gi.is_pragmata()) {
+        return false;
+    }
+
+    return gi.is_dd2() || gi.is_mhrise() || gi.tdb_ver() >= 74;
+}
+
+static bool should_preload_compat_modules(const sdk::GameIdentity& gi) {
+    if (gi.is_pragmata()) {
+        return false;
+    }
+
+    return gi.is_mhrise() || gi.is_dd2() || gi.tdb_ver() >= 74;
+}
+
+static bool should_enable_faulty_file_detector(const sdk::GameIdentity& gi) {
+    if (gi.is_pragmata()) {
+        return false;
+    }
+
+    return gi.tdb_ver() >= 81;
+}
+
+static bool should_enable_loose_file_loader_startup(const sdk::GameIdentity& gi) {
+    if (gi.is_pragmata()) {
+        return false;
+    }
+
+    return true;
+}
+
 void CALLBACK ldr_notification_callback(
     ULONG                       NotificationReason,
     PLDR_DLL_NOTIFICATION_DATA NotificationData,
@@ -235,7 +267,7 @@ try {
             if (full_dll_path.parent_path() == *g_current_game_path) {
                 spdlog::info("LdrRegisterDllNotification: DLL loaded from game directory: {}", utility::narrow(full_dll_name));
 
-                if (sdk::GameIdentity::get().is_dd2() || sdk::GameIdentity::get().is_mhrise() || sdk::GameIdentity::get().tdb_ver() >= 74) {
+                if (should_use_module_storage_workaround(sdk::GameIdentity::get())) {
                     utility::spoof_module_paths_in_exe_dir();
                 }
             }
@@ -345,7 +377,7 @@ REFramework::REFramework(HMODULE reframework_module)
         }
 
         // Do this at least once before setting up our callback.
-        if (gi.is_dd2() || gi.is_mhrise() || gi.tdb_ver() >= 74) {
+        if (should_use_module_storage_workaround(gi)) {
             // Pre-emptively copy all DLL files in the current game directory into our _storage_ directory.
             if (g_current_game_path.has_value()) {
                 const auto dest_path = *g_current_game_path / "_storage_";
@@ -468,7 +500,7 @@ REFramework::REFramework(HMODULE reframework_module)
         spdlog::info("D3D12 loaded");
     }
 
-    if (gi.is_mhrise() || gi.is_dd2() || gi.tdb_ver() >= 74) {
+    if (should_preload_compat_modules(gi)) {
         utility::load_module_from_current_directory(L"openvr_api.dll");
         utility::load_module_from_current_directory(L"openxr_loader.dll");
         LoadLibraryA("dxgi.dll");
@@ -479,9 +511,11 @@ REFramework::REFramework(HMODULE reframework_module)
         }
     }
 
-    LooseTextureLoader::get().early_initialize();
+    if (!gi.is_pragmata()) {
+        LooseTextureLoader::get().early_initialize();
+    }
 
-    if (gi.tdb_ver() >= 81) {
+    if (should_enable_faulty_file_detector(gi)) {
         FaultyFileDetector::early_init();
     }
 
@@ -574,10 +608,10 @@ REFramework::REFramework(HMODULE reframework_module)
     bool renderer_has_render_frame_fn = false;
 
     if (sdk::RETypeDB::get() != nullptr) {
-        auto& loader = LooseFileLoader::get(); // Initialize this really early
+        auto loader = should_enable_loose_file_loader_startup(gi) ? LooseFileLoader::get() : nullptr; // Initialize this really early
         auto &integrity_bypass = IntegrityCheckBypass::get_shared_instance();
 
-        const bool has_faulty_file_detector = gi.tdb_ver() >= 81;
+        const bool has_faulty_file_detector = should_enable_faulty_file_detector(gi);
         if (has_faulty_file_detector) {
             FaultyFileDetector::get(); // Initialize early
         }
@@ -585,7 +619,9 @@ REFramework::REFramework(HMODULE reframework_module)
         const auto config_path = get_persistent_dir(REFrameworkConfig::REFRAMEWORK_CONFIG_NAME.data()).string();
         if (fs::exists(utility::widen(config_path))) {
             utility::Config cfg{ config_path };
-            loader->on_config_load(cfg);
+            if (loader != nullptr) {
+                loader->on_config_load(cfg);
+            }
 
             if (has_faulty_file_detector) {
                 FaultyFileDetector::get()->on_config_load(cfg);
@@ -593,7 +629,7 @@ REFramework::REFramework(HMODULE reframework_module)
             integrity_bypass->on_config_load(cfg);
         }
 
-        if (loader->is_enabled()) {
+        if (loader != nullptr && loader->is_enabled()) {
             loader->hook();
         }
     }
-- 
